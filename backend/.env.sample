# Copy to .env and fill in your values. .env is gitignored.

# Supabase PostgreSQL connection string
# Find it in: Supabase Dashboard → Project Settings → Database → URI tab
DATABASE_URL=postgresql://postgres:yourpassword@db.xxxx.supabase.co:5432/postgres

# JWT signing secret
# Use the Supabase JWT secret for OAuth compatibility:
# Supabase Dashboard → Project Settings → API → JWT Secret
JWT_SECRET=change-me-to-a-long-random-string

# Supabase project URL and anon key (used to validate Google OAuth tokens)
# Find both in: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...

# Your deployed frontend URL (used for CORS in production)
# e.g. https://mywallet-woad-nine.vercel.app
FRONTEND_URL=
